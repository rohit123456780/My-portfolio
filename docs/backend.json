
{
  "entities": {
    "Certification": {
      "title": "Certification",
      "description": "A professional certification or credential.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "issuer": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "id": { "type": "string" }
      },
      "required": ["name", "issuer", "category"]
    },
    "Internship": {
      "title": "Internship",
      "description": "A cybersecurity internship or industrial training placement.",
      "type": "object",
      "properties": {
        "org": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "domain": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["org", "role", "period"]
    },
    "Project": {
      "title": "Project",
      "description": "A technical project or case study.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "org": { "type": "string" },
        "period": { "type": "string" },
        "details": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" }
      },
      "required": ["title", "details", "category"]
    },
    "Experience": {
      "title": "Experience",
      "description": "Primary work experience.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "org": { "type": "string" },
        "period": { "type": "string" },
        "type": { "type": "string" },
        "focus": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["title", "org", "period"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "A professional award or milestone.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "meta": { "type": "string" },
        "isMajor": { "type": "boolean" }
      },
      "required": ["title", "description"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/certifications/{certId}": {
      "schema": "#/backend/entities/Certification",
      "description": "Collection of 97+ credentials."
    },
    "/internships/{internId}": {
      "schema": "#/backend/entities/Internship",
      "description": "Deployment history of 27+ internships."
    },
    "/projects/{projectId}": {
      "schema": "#/backend/entities/Project",
      "description": "Matrix of 14 technical projects."
    },
    "/experience/{expId}": {
      "schema": "#/backend/entities/Experience",
      "description": "Core mission logs."
    },
    "/achievements/{achId}": {
      "schema": "#/backend/entities/Achievement",
      "description": "Distinction belt milestones."
    }
  }
}
