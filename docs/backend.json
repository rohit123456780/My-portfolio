
{
  "entities": {
    "Certification": {
      "title": "Certification",
      "description": "A professional certification or credential.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "issuer": { "type": "string" },
        "category": { "type": "string" },
        "featured": { "type": "boolean" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["name", "issuer", "category"]
    },
    "Internship": {
      "title": "Internship",
      "description": "A cybersecurity internship or industrial training placement.",
      "type": "object",
      "properties": {
        "organization": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "domain": { "type": "string" },
        "description": { "type": "string" },
        "isAdvanced": { "type": "boolean" }
      },
      "required": ["organization", "role", "period", "domain"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "An award, honor, or professional milestone.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "isMajor": { "type": "boolean" }
      },
      "required": ["title", "description", "category"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/certifications/{certId}": {
      "schema": "#/backend/entities/Certification",
      "description": "Collection of professional certifications."
    },
    "/internships/{internId}": {
      "schema": "#/backend/entities/Internship",
      "description": "Historical record of internship deployments."
    },
    "/achievements/{achId}": {
      "schema": "#/backend/entities/Achievement",
      "description": "Record of professional awards and achievements."
    }
  }
}
